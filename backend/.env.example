# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Anthropic API Configuration (for AI duplicate detection)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI Provider Selection
AI_PROVIDER=anthropic  # Options: 'anthropic' or 'openai'
AI_MODEL=claude-3-5-sonnet-20241022  # Claude 3.5 Sonnet (latest)
AI_MAX_TOKENS=4096
AI_COST_LIMIT_PER_USER_PER_MONTH=50.00  # USD

# Instructions:
# 1. Copy this file to .env (in the same directory)
# 2. Replace 'your-api-key-here' with your actual OpenAI API key
# 3. Replace 'your-anthropic-api-key-here' with your Anthropic API key
# 4. Make sure .env is in your .gitignore to keep your key secure
